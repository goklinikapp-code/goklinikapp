# ==============================
# Django Core
# ==============================
DJANGO_ENV=development
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=api.goklinik.com,goklinik.com,www.goklinik.com,localhost,127.0.0.1
API_BASE_URL=http://127.0.0.1:8000
TIME_ZONE=Europe/Istanbul
USE_SQLITE_FOR_TESTS=True

# ==============================
# Supabase Project (Provided credentials)
# ==============================
SUPABASE_PROJECT_ID=your-supabase-project-id
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=replace-with-your-anon-key

# IMPORTANT: Keep DATABASE_URL quoted because password includes '#'.
DATABASE_URL='postgresql://postgres:replace-with-password@db.your-project-id.supabase.co:5432/postgres'
# For Railway + Supabase use the IPv4 pooler URL from Supabase dashboard (recommended).
# Example:
# DATABASE_POOLER_URL='postgresql://postgres.your-project-id:replace-with-password@aws-0-sa-east-1.pooler.supabase.com:6543/postgres'
DATABASE_POOLER_URL=
DATABASE_SSL_REQUIRE=True
# Docker mode also uses the same Supabase DATABASE_URL.

# Optional strict check against Supabase Auth during login
SUPABASE_AUTH_STRICT=False
SUPABASE_PASSWORD_RESET_REDIRECT=https://goklinik.com/reset-password
SUPABASE_OUTBOUND_EMAILS_ENABLED=False
REFERRAL_BASE_URL=https://goklinik.com/ref

# ==============================
# CORS (Frontend clients)
# ==============================
CORS_ALLOWED_ORIGINS=https://goklinik.com,https://www.goklinik.com,http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173,capacitor://localhost

# ==============================
# Supabase Storage via S3-compatible API
# ==============================
SUPABASE_STORAGE_BUCKET=media
SUPABASE_STORAGE_REGION=us-east-1
SUPABASE_S3_ENDPOINT=https://vjhdsqtrdfhmjqrajbty.supabase.co/storage/v1/s3

# Use your own keys for production-grade uploads
SUPABASE_STORAGE_ACCESS_KEY=supabase
SUPABASE_STORAGE_SECRET_KEY=replace-with-service-role-or-s3-secret
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# ==============================
# Celery + Redis
# ==============================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# Docker Compose overrides these to redis://redis:6379/0 automatically.

# ==============================
# Email / Password Recovery
# ==============================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@goklinik.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
GROK_API_KEY=
GROK_MODEL=grok-4-1-fast
GROK_CHAT_ENDPOINT=https://api.x.ai/v1/chat/completions
FRONTEND_BASE_URL=https://goklinik.com
TEAM_INVITE_LOGIN_PATH=/login

# ==============================
# Firebase Cloud Messaging (optional in local, required for production push)
# ==============================
# Service account credentials (env-only; no JSON file in repo)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep \n escaped exactly as provided by Firebase private key
FIREBASE_PRIVATE_KEY=
# Anti-spam: max push sends per user/hour
PUSH_MAX_PER_USER_PER_HOUR=20
# How many hours before appointment to send automatic reminder
APPOINTMENT_REMINDER_HOURS_BEFORE=24
